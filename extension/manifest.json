{
  "manifest_version": 3,
  "name": "AutoStore in Chrome",
  "version": "0.5.1",
  "description": "Lets the AutoStore agent drive your real Chrome (Seller Hub, Seller Central, Etsy Shop Manager, 1688) via a local bridge.",
  "permissions": [
    "tabs",
    "scripting",
    "debugger",
    "storage",
    "activeTab",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "AutoStore in Chrome"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
