{
  "manifest_version": 3,
  "name": "AutoStore",
  "version": "0.6.0",
  "description": "AutoStore in Chrome",
  "permissions": [
    "tabs",
    "scripting",
    "debugger",
    "storage",
    "activeTab",
    "alarms"
  ],
  "host_permissions": [
    "https://*.ebay.com/*",
    "https://*.ebay.co.uk/*",
    "https://*.amazon.com/*",
    "https://*.amazon.co.uk/*",
    "https://*.amazon.co.jp/*",
    "https://*.amazon.de/*",
    "https://*.etsy.com/*",
    "https://*.1688.com/*",
    "https://amos.alibaba.com/*",
    "https://*.aliexpress.com/*",
    "https://*.csp.aliexpress.com/*"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "AutoStore in Chrome"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
